<FilesMatch "\.html">
Header always unset Link
Header always set "Cross-Origin-Resource-Policy" "same-site"
</FilesMatch>

<FilesMatch "\.(avif|jpg)$">
Header always set Cache-Control "max-age=31536000, public"
Header always set "Cross-Origin-Resource-Policy" "same-site"
</FilesMatch>

<FilesMatch "\.avif$">
ForceType image/avif
</FilesMatch>
