RewriteEngine on
RewriteCond %{HTTP_HOST} ^ericperret.org$
RewriteRule ^(.*)$ https://www.ericperret.org/$1 [R=301]

ServerSignature Off

RewriteBase /
DirectorySlash Off

RewriteCond %{HTTP:Accept-encoding} br
RewriteCond %{REQUEST_FILENAME}\.br -s
RewriteRule (.*) $1.br [L,QSA]

RewriteCond %{HTTP:Accept-encoding} gzip
RewriteCond %{REQUEST_FILENAME}.gz -f
RewriteRule (.*) $1.gz [L,QSA]

# SPA routes: canonical URLs are /art, /tea, /photos (no trailing slash).
# Those names also exist as on-disk directories (CSS/JS/images). Without
# DirectorySlash Off above, mod_dir 301s /tea → /tea/ which loops with the
# trailing-slash strip rule below. Fragments live at /art/art.html, etc.
RewriteRule ^(art|tea|photos)/$ /$1 [R=301,L]
RewriteRule ^(art|tea|photos)$ /index.html [L]

ErrorDocument 404 /404/index.html?v=Dj09ogQq4v19RCjM5-JTWw

ExpiresActive on
Header set Cache-Control "public,max-age=2419202"

<FilesMatch ".gz$">
AddEncoding x-gzip .gz
Header set Content-Encoding: gzip
</FilesMatch>

<FilesMatch ".br$">
AddEncoding br .br
Header set Content-Encoding: br
</FilesMatch>

<FilesMatch "\.js">
Header set Vary "Accept-Encoding"
AddDefaultCharset UTF-8
ForceType text/javascript
Header always set "Cross-Origin-Resource-Policy" "same-site"
Header set Cache-Control "public,max-age=31536000"
</FilesMatch>

<FilesMatch "\.css">
Header set Vary "Accept-Encoding"
AddDefaultCharset UTF-8
ForceType text/css
Header always set "Cross-Origin-Resource-Policy" "same-site"
Header set Cache-Control "public,max-age=31536000"
</FilesMatch>

<FilesMatch "\.html">
Header always set Link "<https://fonts.googleapis.com/css2?family=Roboto+Condensed:wght@900&family=Inter:wght@400;700&family=Playfair+Display:wght@900&display=swap>;as=style;rel=preload;fetchpriority=high,<https://fonts.gstatic.com>;rel=preconnect;crossorigin,</img/bg0.avif?v=cDOk2pqo9Bsbqaf17vLwyw>;as=image;rel=preload;fetchpriority=high,</img/bg1.webp?v=gmEaQ238fBlAEWY_brTtWA>;as=image;rel=preload,</img/bg7.avif?v=ULgd5PnVlwclM7zFybFM8w>;as=image;rel=preload,</unicorns-and-rainbows.css?v=d-1PL8OpeLebgNo3i3Pe_A>;rel=preload;as=style,</script-of-awesomeness.js?v=wOo-NxLJ6o7iWS4_q4Twcg>;rel=modulepreload,</books/library.json?v=nrdP-0hgnHTr9qkJ9mxlKw>;rel=preload;as=fetch;crossorigin,<https://www.googletagmanager.com>;rel=preconnect" "expr=%{THE_REQUEST} =~ m#^GET /(index\.html|art/?|tea/?|photos/?)? HTTP#"
Header always append Link "</art/art.css?v=fycA8Odzvmm__C-deVYZ8g>;rel=preload;as=style,</art/art.js?v=mA9fIQXRFJghMhyH_Eve2A>;rel=modulepreload,</art/art.html?v=uvIdnOgoujBFUAG_7PDJPg>;rel=preload;as=fetch;crossorigin" "expr=%{THE_REQUEST} =~ m#^GET /art/? HTTP#"
Header always append Link "</art/art.css?v=fycA8Odzvmm__C-deVYZ8g>;rel=prefetch,</art/art.js?v=mA9fIQXRFJghMhyH_Eve2A>;rel=prefetch,</art/art.html?v=uvIdnOgoujBFUAG_7PDJPg>;rel=prefetch" "expr=%{THE_REQUEST} =~ m#^GET /(index\.html|art/?|tea/?|photos/?)? HTTP# && %{THE_REQUEST} !~ m#^GET /art/? HTTP#"
Header always append Link "</tea/tea.css?v=mPQD6FiKhdRQ83dBqP7Avg>;rel=preload;as=style,</tea/tea.js?v=NrMFpDUw3qDCz07Sx5olkQ>;rel=modulepreload,</tea/tea.html?v=43S5lBrkLvtsLK57oGgb-w>;rel=preload;as=fetch;crossorigin" "expr=%{THE_REQUEST} =~ m#^GET /tea/? HTTP#"
Header always append Link "</tea/tea.css?v=mPQD6FiKhdRQ83dBqP7Avg>;rel=prefetch,</tea/tea.js?v=NrMFpDUw3qDCz07Sx5olkQ>;rel=prefetch,</tea/tea.html?v=43S5lBrkLvtsLK57oGgb-w>;rel=prefetch" "expr=%{THE_REQUEST} =~ m#^GET /(index\.html|art/?|tea/?|photos/?)? HTTP# && %{THE_REQUEST} !~ m#^GET /tea/? HTTP#"
Header always set "Referrer-Policy" "no-referrer"
Header always set "Cross-Origin-Embedder-Policy" "credentialless"
Header always set "X-UA-Compatible" "IE=edge"
Header always append X-Frame-Options DENY
Header set Vary "Accept-Encoding"
Header always set "Content-Security-Policy" "upgrade-insecure-requests;default-src 'none';script-src 'self' 'sha256-I/2MSZRcaETmHpt/gbnZIuMGIKBisPLfPmteUx/WHdY=' 'sha256-gZiWBOWKghllTz52afdCzCwLyQj46lJInJAx9YY1bqg=' 'sha256-CWpOQpjtR82aholVEnJ/z/GSf5SxQVNZzZ0p5O1zdbw=' 'sha256-oQtyRwkYcuxDD0eldlqy3S4unr6TzPjd2Gj7cR5R0Oc=' 'sha256-VfqGT1c6m8Sp31M1gtyidxuPo3zoKY3gOpbkaAkr8pc=' https://www.googletagmanager.com/gtag/js *.google-analytics.com;style-src 'self' 'sha256-s4luA1dUp9XWuHO6rZF8OH6C15WnY5r6vJdHuoi5HUU=' 'sha256-biC4kOKLSc9YD3TPQJV4uAlrnZyG2xuQsUaGrTRkbpA=' https://fonts.googleapis.com;connect-src 'self';media-src 'self';img-src data: 'self' https://www.googletagmanager.com https://www.google-analytics.com https://covers.openlibrary.org https://m.media-amazon.com; font-src data: https://fonts.gstatic.com;frame-src https://www.youtube-nocookie.com https://www.google.com;form-action 'none';base-uri 'self';frame-ancestors 'none'"
Header always set "Speculation-Rules" "\"/prerender.json?v=6ajp3knV1SccoUTy_6uWDw\""
Header always set "Strict-Transport-Security" "max-age=31536000"
ForceType text/html
Header always set "Cloudflare-CDN-Cache-Control" "public,max-age=2419201"
Header set Cache-Control "public,max-age=900"
Header set Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"

AddDefaultCharset UTF-8
</FilesMatch>

<FilesMatch "\.ico\.gz$">
AddEncoding x-gzip .gz
Header set Content-Encoding: gzip
Header set Vary "Accept-Encoding"
Header set Cache-Control "max-age=604800,public"
ForceType image/x-icon
Header always set "Cross-Origin-Resource-Policy" "same-site"
</FilesMatch>

<FilesMatch "\.ico\.br$">
AddEncoding br .br
Header set Content-Encoding: br
Header set Vary "Accept-Encoding"
Header set Cache-Control "max-age=604800,public"
ForceType image/x-icon
Header always set "Cross-Origin-Resource-Policy" "same-site"
</FilesMatch>

<FilesMatch "\.json">
Header set Vary "Accept-Encoding"
ForceType "application/json; charset=utf-8"
Header always set "Cross-Origin-Resource-Policy" "same-site"
Header set Cache-Control "public,max-age=31536000"
</FilesMatch>

<FilesMatch "prerender\.json(\.(br|gz))?$">
Header set Vary "Accept-Encoding"
Header set Cache-Control "max-age=604800,public"
ForceType application/speculationrules+json
Header always set "Cross-Origin-Resource-Policy" "same-site"
</FilesMatch>

Header always set "X-Content-Type-Options" "nosniff"
