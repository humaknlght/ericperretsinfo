{
  "compilerOptions": {
    "target": "ES2024",       // Compile to modern JavaScript (ES2024)
    "module": "ESNext",       // Plain script emit (no import/export in sources); "none" is deprecated in TS 6+
    "strict": true,           // Enable all strict type-checking options
    "lib": ["ES2024", "DOM"], // Include type definitions for ES2024 and the Browser DOM
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,        // Generate source maps for easier debugging
    "alwaysStrict": true,     // Always emit “use strict” for each source file
    "rootDir": "../src",      // TypeScript sources live in src/ (prod/ is build output)
    "outDir": "./prod"        // Emit compiled JS into prod/ during build
  },
  "include": [
    "../src/**/*.ts"          // Source .ts files (prod/ is created by build.sh and may not exist yet)
  ]
}